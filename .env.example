# 腾讯云 API 密钥
# 获取地址: https://console.cloud.tencent.com/cam/capi
TENCENTCLOUD_SECRET_ID=your-secret-id-here
TENCENTCLOUD_SECRET_KEY=your-secret-key-here

# 主域名配置
# 用于申请泛域名证书和配置服务
DOMAIN_NAME=codebuff.tech

# ACME 证书申请邮箱
ACME_EMAIL=your-email@example.com

# Dashboard 认证信息
# 生成方法: htpasswd -nB admin | sed 's/\$/\$\$/g'
# 或使用在线工具: https://hostingcanada.org/htpasswd-generator/
DASHBOARD_USERS=admin:$$2y$$05$$xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# my-pages 配置
MY_PAGES_VERSION=latest
MY_PAGES_DOMAIN_NAME=codebuff.tech

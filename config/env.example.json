{
  "version": 2,
  "traefik": {
    "domains": [
      "example.com",
      "example.net"
    ]
  },
  "files": {
    "infrastructure/traefik/.env": {
      "DOMAIN_NAME": "example.com",
      "ACME_EMAIL": "your-email@example.com",
      "DASHBOARD_USERS": "admin:$2y$05$xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
    },
    "infrastructure/traefik/.env.runtime": {
      "TENCENTCLOUD_SECRET_ID": "your-secret-id-here",
      "TENCENTCLOUD_SECRET_KEY": "your-secret-key-here"
    },
    "infrastructure/postgres/.env": {
      "POSTGRES_MAX_CONNECTIONS": "50"
    },
    "infrastructure/postgres/.env.runtime": {
      "POSTGRES_USER": "postgres",
      "POSTGRES_PASSWORD": "replace-with-a-long-random-password",
      "POSTGRES_DB": "postgres",
      "POSTGRES_INITDB_ARGS": "--auth-host=scram-sha-256"
    },
    "infrastructure/garage/.env": {
      "GARAGE_PUBLIC_DOMAIN": "media.example.com",
      "GARAGE_PUBLIC_BUCKET": "public-media",
      "GARAGE_PUBLIC_BUCKET_MAX_SIZE": "5GiB",
      "GARAGE_PUBLIC_BUCKET_MAX_OBJECTS": "100000"
    },
    "infrastructure/garage/.env.runtime": {
      "GARAGE_RPC_SECRET": "replace-with-64-lowercase-hex-characters",
      "GARAGE_DEFAULT_ACCESS_KEY": "GKreplace-with-32-lowercase-hex-characters",
      "GARAGE_DEFAULT_SECRET_KEY": "replace-with-64-lowercase-hex-characters"
    },
    "apps/codebuff-next/.env": {
      "IMAGE_REPOSITORY": "ghcr.io/example/codebuff-next",
      "APP_DOMAIN": "codebuff-next.example.com",
      "IMAGE_TAG": "sha-REPLACE_ME"
    },
    "apps/codebuff-next/.env.runtime": {
      "PG_USER": "codebuff_next_runtime",
      "PG_PWD": "replace-with-a-long-random-runtime-password"
    },
    "apps/codebuff-next/.env.migration": {
      "PG_USER": "codebuff_next_migration",
      "PG_PWD": "replace-with-a-long-random-migration-password"
    },
    "apps/my-pages/.env": {
      "IMAGE_REPOSITORY": "ghcr.io/example/my-pages",
      "APP_DOMAIN": "my-pages.example.com",
      "IMAGE_TAG": "sha-REPLACE_ME"
    }
  }
}
